#!/usr/bin/env python3
"""Install the agentic delivery pipeline into a project or user profile."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
from pathlib import Path
import re
import sys
from typing import Iterable


SOURCE_ROOT = Path(__file__).resolve().parent.parent
ROLE_FILES = {
    "designer": "DESIGNER.md",
    "engineer": "ENGINEER.md",
    "qa": "QA.md",
    "sre": "SRE.md",
    "infosec": "INFOSEC.md",
}
BEGIN = "<!-- agentic-delivery:begin -->"
END = "<!-- agentic-delivery:end -->"
GENERATED = "Generated by agents-install; edit the source agents repository, not this snapshot."


class InstallError(RuntimeError):
    pass


def sha256_text(value: str) -> str:
    return hashlib.sha256(value.encode("utf-8")).hexdigest()


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def parse_frontmatter(path: Path) -> tuple[dict[str, str], str]:
    text = read_text(path)
    match = re.match(r"\A---\s*\n(.*?)\n---\s*\n?(.*)\Z", text, re.DOTALL)
    if not match:
        raise InstallError(f"Missing YAML frontmatter in {path}")
    metadata: dict[str, str] = {}
    for line in match.group(1).splitlines():
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        key, separator, value = line.partition(":")
        if not separator:
            raise InstallError(f"Unsupported frontmatter line in {path}: {line}")
        metadata[key.strip()] = value.strip()
    for required in ("name", "description"):
        if not metadata.get(required):
            raise InstallError(f"Missing {required} in {path}")
    return metadata, match.group(2).strip() + "\n"


def role_sources() -> dict[str, tuple[dict[str, str], str]]:
    result: dict[str, tuple[dict[str, str], str]] = {}
    for role, filename in ROLE_FILES.items():
        result[role] = parse_frontmatter(SOURCE_ROOT / ".claude" / "agents" / filename)
    return result


def yaml_scalar(value: str) -> str:
    return json.dumps(value, ensure_ascii=False)


def render_claude_agent(metadata: dict[str, str], body: str) -> str:
    fields = [
        "---",
        f"name: {metadata['name']}",
        f"description: {yaml_scalar(metadata['description'])}",
    ]
    if metadata.get("tools"):
        fields.append(f"tools: {metadata['tools']}")
    if metadata.get("permissionMode"):
        fields.append(f"permissionMode: {metadata['permissionMode']}")
    fields.extend(
        [
            f"model: {metadata.get('model', 'inherit')}",
            "---",
            f"<!-- {GENERATED} -->",
            "",
            body.rstrip(),
            "",
        ]
    )
    return "\n".join(fields)


def render_codex_agent(role: str, metadata: dict[str, str], body: str) -> str:
    if "'''" in body:
        raise InstallError(f"Role body for {role} contains unsupported TOML delimiter")
    sandbox = "read-only" if role in {"qa", "infosec"} else "workspace-write"
    return (
        f"# {GENERATED}\n"
        f"name = {json.dumps(role)}\n"
        f"description = {json.dumps(metadata['description'])}\n"
        f"nickname_candidates = [{json.dumps(role.title())}]\n"
        f"sandbox_mode = {json.dumps(sandbox)}\n"
        "developer_instructions = '''\n"
        f"{body.rstrip()}\n"
        "'''\n"
    )


def render_role_skill(role: str, metadata: dict[str, str], body: str) -> str:
    if role == "infosec":
        description = (
            "Runs the optional Infosec security-review role only when explicitly invoked. "
            f"{metadata['description']} Never activate implicitly or as a routine delivery phase."
        )
    else:
        description = (
            f"Acts as the {role.title()} phase of the agentic delivery pipeline. "
            f"{metadata['description']} Invoke explicitly when the user names {role.title()} "
            f"or requests the {role.upper()} phase."
        )
    return (
        "---\n"
        f"name: {role}\n"
        f"description: {yaml_scalar(description)}\n"
        "---\n\n"
        f"<!-- {GENERATED} -->\n\n"
        f"{body.rstrip()}\n"
    )


def render_openai_yaml(role: str) -> str:
    if role == "infosec":
        short = "Run an on-demand security audit"
        prompt = "Use $infosec to perform a scoped, read-only security audit."
    else:
        short = f"Run the {role.title()} delivery phase"
        prompt = f"Use ${role} to run the {role.title()} phase for the current task."
    return (
        "interface:\n"
        f"  display_name: {yaml_scalar(role.title())}\n"
        f"  short_description: {yaml_scalar(short)}\n"
        f"  default_prompt: {yaml_scalar(prompt)}\n"
        "policy:\n"
        f"  allow_implicit_invocation: {'false' if role == 'infosec' else 'true'}\n"
    )


def render_gemini_agent(role: str, metadata: dict[str, str], body: str) -> str:
    fields = [
        "---",
        f"name: {role}",
        f"description: {yaml_scalar(metadata['description'])}",
        "kind: local",
    ]
    if role == "infosec":
        fields.extend(
            [
                "tools:",
                "  - read_file",
                "  - grep_search",
                "  - run_shell_command",
                "max_turns: 40",
            ]
        )
    fields.extend(
        [
            "---",
            f"<!-- {GENERATED} -->",
            "",
            body.rstrip(),
            "",
        ]
    )
    return "\n".join(fields)


def pipeline_skill_files(prefix: Path) -> dict[Path, str]:
    source = SOURCE_ROOT / "adapters" / "shared" / "skills" / "agentic-delivery"
    files = {
        prefix / "SKILL.md": read_text(source / "SKILL.md"),
        prefix / "agents" / "openai.yaml": read_text(source / "agents" / "openai.yaml"),
        prefix / "references" / "DELIVERY.md": read_text(SOURCE_ROOT / "CLAUDE.md"),
        prefix / "references" / "SCALABILITY.md": read_text(SOURCE_ROOT / "SCALABILITY.md"),
    }
    for role, filename in ROLE_FILES.items():
        _, body = parse_frontmatter(SOURCE_ROOT / ".claude" / "agents" / filename)
        files[prefix / "references" / "roles" / f"{role}.md"] = body
    return files


def add_shared_skills(files: dict[Path, str], base: Path) -> None:
    roles = role_sources()
    files.update(pipeline_skill_files(base / "agentic-delivery"))
    for role, (metadata, body) in roles.items():
        prefix = base / role
        files[prefix / "SKILL.md"] = render_role_skill(role, metadata, body)
        files[prefix / "agents" / "openai.yaml"] = render_openai_yaml(role)


def add_claude_agents(files: dict[Path, str], base: Path) -> None:
    for role, (metadata, body) in role_sources().items():
        files[base / f"{role}.md"] = render_claude_agent(metadata, body)


def add_codex_agents(files: dict[Path, str], base: Path) -> None:
    for role, (metadata, body) in role_sources().items():
        files[base / f"{role}.toml"] = render_codex_agent(role, metadata, body)


def add_gemini_agents(files: dict[Path, str], base: Path) -> None:
    for role, (metadata, body) in role_sources().items():
        files[base / f"{role}.md"] = render_gemini_agent(role, metadata, body)


def project_files(harnesses: set[str]) -> dict[Path, str]:
    files: dict[Path, str] = {
        Path(".agents/pipeline/DELIVERY.md"): read_text(SOURCE_ROOT / "CLAUDE.md"),
        Path(".agents/pipeline/SCALABILITY.md"): read_text(SOURCE_ROOT / "SCALABILITY.md"),
        Path(".agents/pipeline/VERSION"): read_text(SOURCE_ROOT / "VERSION"),
    }
    for role, filename in ROLE_FILES.items():
        _, body = parse_frontmatter(SOURCE_ROOT / ".claude" / "agents" / filename)
        files[Path(".agents/pipeline/roles") / f"{role}.md"] = body
    if "claude" in harnesses:
        add_claude_agents(files, Path(".claude/agents"))
    if "codex" in harnesses:
        add_codex_agents(files, Path(".codex/agents"))
    if "gemini" in harnesses:
        add_gemini_agents(files, Path(".gemini/agents"))
    if harnesses.intersection({"codex", "gemini", "antigravity"}):
        add_shared_skills(files, Path(".agents/skills"))
    if "antigravity" in harnesses:
        files[Path(".agents/rules/agentic-delivery.md")] = read_text(
            SOURCE_ROOT / "adapters" / "antigravity" / "plugin" / "rules" / "agentic-delivery.md"
        )
    return files


def global_files(harnesses: set[str]) -> dict[Path, str]:
    files: dict[Path, str] = {}
    if "claude" in harnesses:
        add_claude_agents(files, Path(".claude/agents"))
    if "codex" in harnesses:
        add_codex_agents(files, Path(".codex/agents"))
        add_shared_skills(files, Path(".agents/skills"))
    if "gemini" in harnesses:
        add_gemini_agents(files, Path(".gemini/agents"))
        add_shared_skills(files, Path(".agents/skills"))
    if "antigravity" in harnesses:
        plugin = Path(".gemini/config/plugins/agentic-delivery")
        files[plugin / "plugin.json"] = read_text(
            SOURCE_ROOT / "adapters" / "antigravity" / "plugin" / "plugin.json"
        )
        files[plugin / "rules" / "agentic-delivery.md"] = read_text(
            SOURCE_ROOT / "adapters" / "antigravity" / "plugin" / "rules" / "agentic-delivery.md"
        )
        add_shared_skills(files, plugin / "skills")
    return files


def claude_block() -> str:
    return (
        f"{BEGIN}\n"
        "## Agentic delivery pipeline\n\n"
        "@.agents/pipeline/DELIVERY.md\n"
        f"{END}"
    )


def codex_block() -> str:
    return (
        f"{BEGIN}\n"
        "## Agentic delivery pipeline\n\n"
        "Use the installed `agentic-delivery` skill for end-to-end product work. "
        "When the user names Designer, Engineer, QA, or SRE, delegate to the matching "
        "custom agent when useful and enforce that phase's contract. Keep dependent phases "
        "sequential and keep QA independent/read-only. Repository-specific instructions above "
        "this block define the project's commands, architecture, deployment, and risk boundaries. "
        "Infosec is an optional read-only role: invoke it only when the user explicitly requests "
        "Infosec or a security audit, vulnerability assessment, supply-chain review, secret scan, "
        "or bounded penetration test.\n"
        f"{END}"
    )


def merge_managed_block(current: str, block: str) -> str:
    pattern = re.compile(re.escape(BEGIN) + r".*?" + re.escape(END), re.DOTALL)
    matches = pattern.findall(current)
    if len(matches) > 1:
        raise InstallError("Instruction file contains multiple agentic-delivery managed blocks")
    if matches:
        return pattern.sub(block, current).rstrip() + "\n"
    if not current.strip():
        return block + "\n"
    return current.rstrip() + "\n\n" + block + "\n"


def load_lock(path: Path, force: bool) -> dict[str, object]:
    if not path.exists():
        return {}
    try:
        payload = json.loads(read_text(path))
        files = payload.get("files", {})
        if not isinstance(files, dict):
            raise ValueError("files must be an object")
        harnesses = payload.get("harnesses", [])
        if not isinstance(harnesses, list):
            raise ValueError("harnesses must be an array")
        payload["files"] = {str(key): str(value) for key, value in files.items()}
        payload["harnesses"] = [str(value) for value in harnesses]
        return payload
    except (json.JSONDecodeError, OSError, ValueError) as exc:
        if force:
            return {}
        raise InstallError(f"Cannot read lock file {path}: {exc}; use --force to replace it") from exc


def check_safe(path: Path, relative: Path, previous: dict[str, str], force: bool) -> None:
    if not path.exists() or force:
        return
    current_hash = sha256_text(read_text(path))
    expected_old = previous.get(relative.as_posix())
    if expected_old and current_hash == expected_old:
        return
    raise InstallError(
        f"Refusing to overwrite modified or unmanaged file: {path}\n"
        "Move the file, reconcile it with the generated version, or re-run with --force."
    )


def lock_content(
    files: dict[Path, str],
    harnesses: set[str],
    scope: str,
    previous_lock: dict[str, object],
) -> str:
    file_hashes = {
        str(path): str(value)
        for path, value in dict(previous_lock.get("files", {})).items()
    }
    file_hashes.update(
        {
            path.as_posix(): sha256_text(content)
            for path, content in sorted(files.items(), key=lambda item: item[0].as_posix())
        }
    )
    installed_harnesses = {
        str(value) for value in list(previous_lock.get("harnesses", []))
    }.union(harnesses)
    fingerprint = sha256_text(json.dumps(file_hashes, sort_keys=True, separators=(",", ":")))
    payload = {
        "schema": 1,
        "package": "agentic-delivery",
        "version": read_text(SOURCE_ROOT / "VERSION").strip(),
        "scope": scope,
        "harnesses": sorted(installed_harnesses),
        "content_sha256": fingerprint,
        "files": dict(sorted(file_hashes.items())),
    }
    return json.dumps(payload, indent=2, sort_keys=True) + "\n"


def parse_harnesses(raw: str) -> set[str]:
    values = {item.strip().lower() for item in raw.split(",") if item.strip()}
    allowed = {"all", "claude", "codex", "gemini", "antigravity"}
    unknown = values - allowed
    if unknown:
        raise InstallError(f"Unknown harness: {', '.join(sorted(unknown))}")
    if not values or "all" in values:
        return {"claude", "codex", "gemini", "antigravity"}
    return values


def print_changes(changes: Iterable[tuple[str, Path]]) -> None:
    for action, path in changes:
        print(f"{action:9} {path}")


def install(args: argparse.Namespace) -> int:
    harnesses = parse_harnesses(args.harness)
    if args.global_install:
        if args.target is not None:
            raise InstallError("Do not pass a project target with --global")
        root = Path.home()
        files = global_files(harnesses)
        lock_relative = Path(".agents/agentic-delivery.lock.json")
        managed: dict[Path, str] = {}
        scope = "global"
    else:
        root = Path(args.target or os.getcwd()).expanduser().resolve()
        if not root.is_dir():
            raise InstallError(f"Target directory does not exist: {root}")
        files = project_files(harnesses)
        lock_relative = Path(".agents/agentic-delivery.lock.json")
        managed = {}
        if "claude" in harnesses:
            managed[Path("CLAUDE.md")] = claude_block()
        if "codex" in harnesses:
            managed[Path("AGENTS.md")] = codex_block()
        scope = "project"

    lock_path = root / lock_relative
    previous_lock = load_lock(lock_path, args.force)
    previous = {
        str(path): str(value)
        for path, value in dict(previous_lock.get("files", {})).items()
    }
    desired_lock = lock_content(files, harnesses, scope, previous_lock)
    changes: list[tuple[str, Path]] = []
    drift: list[Path] = []

    for relative, content in sorted(files.items(), key=lambda item: item[0].as_posix()):
        destination = root / relative
        if destination.exists() and read_text(destination) == content:
            changes.append(("unchanged", destination))
            continue
        if args.check:
            drift.append(destination)
            changes.append(("drift", destination))
            continue
        check_safe(destination, relative, previous, args.force)
        changes.append(("update" if destination.exists() else "create", destination))
        if not args.dry_run:
            destination.parent.mkdir(parents=True, exist_ok=True)
            destination.write_text(content, encoding="utf-8")

    for relative, block in managed.items():
        destination = root / relative
        current = read_text(destination) if destination.exists() else ""
        desired = merge_managed_block(current, block)
        if current == desired:
            changes.append(("unchanged", destination))
            continue
        if args.check:
            drift.append(destination)
            changes.append(("drift", destination))
            continue
        changes.append(("update" if destination.exists() else "create", destination))
        if not args.dry_run:
            destination.parent.mkdir(parents=True, exist_ok=True)
            destination.write_text(desired, encoding="utf-8")

    current_lock = read_text(lock_path) if lock_path.exists() else ""
    if current_lock != desired_lock:
        if args.check:
            drift.append(lock_path)
            changes.append(("drift", lock_path))
        else:
            changes.append(("update" if lock_path.exists() else "create", lock_path))
            if not args.dry_run:
                lock_path.parent.mkdir(parents=True, exist_ok=True)
                lock_path.write_text(desired_lock, encoding="utf-8")
    else:
        changes.append(("unchanged", lock_path))

    print_changes(changes)
    label = "global profile" if args.global_install else str(root)
    if args.check:
        if drift:
            print(f"\nDrift detected in {len(drift)} file(s) for {label}.", file=sys.stderr)
            return 1
        print(f"\nAgentic delivery {read_text(SOURCE_ROOT / 'VERSION').strip()} is current in {label}.")
        return 0
    verb = "Would install" if args.dry_run else "Installed"
    print(f"\n{verb} agentic delivery {read_text(SOURCE_ROOT / 'VERSION').strip()} for {label}.")
    if not args.global_install:
        print("Add project-specific build, test, deploy, architecture, and risk notes above the managed blocks.")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Install the Designer, Engineer, QA, SRE, and on-demand Infosec roles."
    )
    parser.add_argument(
        "target",
        nargs="?",
        help="Project directory to install into (defaults to the current directory)",
    )
    parser.add_argument(
        "--global",
        dest="global_install",
        action="store_true",
        help="Install user-scoped adapters for all repositories",
    )
    parser.add_argument(
        "--harness",
        default="all",
        help="Comma-separated: all, claude, codex, gemini, antigravity (default: all)",
    )
    parser.add_argument("--dry-run", action="store_true", help="Show changes without writing")
    parser.add_argument("--check", action="store_true", help="Exit nonzero if the installation is missing or stale")
    parser.add_argument("--force", action="store_true", help="Replace modified or unmanaged generated files")
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    if args.check and args.dry_run:
        parser.error("--check and --dry-run cannot be combined")
    try:
        return install(args)
    except InstallError as exc:
        print(f"agents-install: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
